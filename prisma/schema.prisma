// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum BookingSource {
  customer_direct
  agent
  online
  phone
  email
  walk_in
  corporate
  other

  @@map("booking_source")
}

enum PaymentTerms {
  due_on_receipt
  net_7
  net_15
  net_30
  pay_on_departure
  pay_on_arrival

  @@map("payment_terms")
}

enum ScheduleStatus {
  building
  draft
  approved
  published
  cancelled
  pilot_assigned
  loadsheet_generated
  in_progress
  completed

  @@map("schedule_status")
}

enum FlightLegStatus {
  scheduled
  active
  completed
  cancelled

  @@map("flight_leg_status")
}

enum PilotAssignmentRole {
  captain
  first_officer
  relief

  @@map("pilot_assignment_role")
}

enum PilotAssignmentStatus {
  assigned
  confirmed
  declined
  checked_in
  completed
  cancelled

  @@map("pilot_assignment_status")
}

enum NoFlyRuleType {
  recurring
  one_off

  @@map("no_fly_rule_type")
}

enum InvoiceStatus {
  draft
  issued
  paid
  overdue
  cancelled
  written_off

  @@map("invoice_status")
}

enum InvoiceItemType {
  fare
  passenger_fee
  freight
  fuel_surcharge
  cargo
  baggage
  cancellation_fee
  adjustment
  other

  @@map("invoice_item_type")
}

enum AccountType {
  asset
  liability
  equity
  revenue
  expense

  @@map("account_type")
}

enum JournalEntryType {
  payment
  refund
  invoice_issued
  invoice_payment
  reconciliation
  fee
  adjustment

  @@map("journal_entry_type")
}

enum PaymentReminderType {
  payment_due
  overdue_1d
  overdue_7d
  overdue_30d

  @@map("payment_reminder_type")
}

enum ReminderStatus {
  pending
  sent
  failed
  cancelled

  @@map("reminder_status")
}

enum StripePaymentStatus {
  pending
  requires_payment_method
  requires_confirmation
  requires_action
  processing
  succeeded
  failed
  refunded
  partially_refunded

  @@map("stripe_payment_status")
}

enum ReconciliationStatus {
  unmatched
  matched
  disputed

  @@map("reconciliation_status")
}

enum ExportType {
  csv
  xml
  xero
  quickbooks
  sage
  other

  @@map("export_type")
}

enum ExportFormat {
  csv
  xml
  json

  @@map("export_format")
}

enum ExportStatus {
  completed
  failed
  partial

  @@map("export_status")
}

// ============================================================================
// CORE TABLES (Migration 001)
// ============================================================================

/// Migration tracking table
model migrations {
  id         Int       @id @default(autoincrement())
  filename   String    @unique @db.VarChar(255)
  applied_at DateTime  @default(now()) @db.Timestamptz()

  @@map("_migrations")
}

/// User accounts
model users {
  id                      Int       @id @default(autoincrement())
  name                    String    @db.VarChar(255)
  email                   String    @unique @db.VarChar(255)
  password                String    @db.VarChar(255)
  role                    String    @default("passenger") @db.VarChar(50)
  is_active               Boolean   @default(true)
  phone                   String?   @db.VarChar(50)
  city                    String?   @db.VarChar(255)
  date_of_birth           DateTime? @db.Date
  residency               String?   @db.VarChar(50)
  id_document_type        String?   @db.VarChar(50)
  id_document_number      String?   @db.VarChar(100)
  nationality             String?   @db.VarChar(100)
  emergency_contact_name  String?   @db.VarChar(255)
  emergency_contact_phone String?   @db.VarChar(50)
  clothed_body_weight_kg  Decimal?  @db.Decimal(5, 1)
  residency_status        String?   @db.VarChar(50)
  created_at              DateTime  @default(now()) @db.Timestamptz()
  updated_at              DateTime  @default(now()) @db.Timestamptz()

  bookings                        bookings[]                        @relation("booking_user")
  bookings_created_by             bookings[]                        @relation("booking_created_by")
  bookings_cancelled_by           bookings[]                        @relation("booking_cancelled_by")
  booking_passengers              booking_passengers[]
  notifications                   notifications[]
  pilots                          pilots[]
  user_roles                      user_roles[]
  user_roles_assigned             user_roles[]                      @relation("user_role_assigned_by")
  audit_log_entries               audit_log[]                       @relation("audit_actor")
  audit_log_assigned              audit_log[]                       @relation("audit_assigned_by")
  schedules_created               schedules[]                       @relation("schedule_created_by")
  schedules_updated               schedules[]                       @relation("schedule_updated_by")
  schedules_approved              schedules[]                       @relation("schedule_approved_by")
  schedules_published             schedules[]                       @relation("schedule_published_by")
  schedules_cancelled             schedules[]                       @relation("schedule_cancelled_by")
  invoices_created                invoices[]                        @relation("invoice_created_by")
  accounting_journal_entries  accounting_journal_entries[]      @relation("journal_created_by")
  accounting_journal_approved     accounting_journal_entries[]      @relation("journal_approved_by")
  export_logs                     export_log[]
  bank_transactions_matched       bank_transactions[]               @relation("bank_matched_by")
  no_fly_rules                    no_fly_rules[]
  pilot_assignments_assigned_by   pilot_assignments[]               @relation("pilot_assignment_assigned_by")
  aircraft_assignments_assigned_by aircraft_assignments[]            @relation("aircraft_assignment_assigned_by")
  loadsheets_finalized             loadsheets[]                      @relation("loadsheet_finalized_by")
  loadsheet_audit_entries          loadsheet_audit_log[]              @relation("loadsheet_audit_actor")
  published_schedules              published_schedules[]              @relation("published_by_user")
  booking_leg_passengers_checked  booking_leg_passengers[]          @relation("blp_checked_in_by")
  payments_reconciled             payments[]
  password_reset_tokens           password_reset_tokens[]
  email_verification_tokens       email_verification_tokens[]
  time_templates                  time_templates[]

  @@index([role])
  @@index([is_active])
  @@map("users")
}

/// Airports / airstrips
model aerodromes {
  id                       Int       @id @default(autoincrement())
  code                     String    @unique @db.VarChar(10)
  name                     String    @db.VarChar(255)
  city                     String?   @db.VarChar(255)
  manufacturer             String?   @db.VarChar(100)
  model                    String?   @db.VarChar(100)
  runway_length            Decimal?  @db.Decimal(6, 1)
  runway_type              String?   @db.VarChar(50)
  latitude                 Decimal?  @db.Decimal(9, 6)
  longitude                Decimal?  @db.Decimal(9, 6)
  timezone                 String    @default("Atlantic/Stanley") @db.VarChar(50)
  is_active                Boolean   @default(true)
  mtow_limit_kg            Decimal?  @db.Decimal(10, 2)
  mlw_limit_kg             Decimal?  @db.Decimal(10, 2)
  fuel_available           Boolean   @default(false)
  operating_hours          String?   @db.VarChar(50)
  pilot_briefing_required  Boolean   @default(false)
  created_at               DateTime  @default(now()) @db.Timestamptz()
  updated_at               DateTime  @default(now()) @db.Timestamptz()

  flights_origin              flights[]           @relation("flight_origin")
  flights_destination         flights[]           @relation("flight_destination")
  fare_routes_origin          fare_routes[]       @relation("fare_route_origin")
  fare_routes_destination     fare_routes[]       @relation("fare_route_destination")
  aerodrome_distances_origin  aerodrome_distances[] @relation("distance_origin")
  aerodrome_distances_dest    aerodrome_distances[] @relation("distance_destination")
  aerodrome_headings_origin   aerodrome_headings[]  @relation("heading_origin")
  aerodrome_headings_dest     aerodrome_headings[]  @relation("heading_destination")
  booking_legs_origin         booking_legs[]      @relation("bl_origin")
  booking_legs_destination    booking_legs[]      @relation("bl_destination")

  @@index([code])
  @@map("aerodromes")
}

/// Aircraft fleet
model aircraft {
  id                    Int       @id @default(autoincrement())
  registration          String    @unique @db.VarChar(20)
  type                  String    @db.VarChar(100)
  manufacturer          String?   @db.VarChar(100)
  model                 String?   @db.VarChar(100)
  year                  Int?
  seat_count            Int
  empty_weight_kg       Decimal   @default(0) @db.Decimal(7, 1)
  max_takeoff_weight_kg Decimal?  @db.Decimal(7, 1)
  max_payload_kg        Decimal?  @db.Decimal(7, 1)
  fuel_capacity_kg      Decimal?  @db.Decimal(7, 1)
  max_freight_weight    Decimal   @default(0) @db.Decimal(10, 2)
  is_active             Boolean   @default(true)

  // ── Weight & Balance arm positions (metres from datum) ─────────────────────
  empty_arm_m           Decimal?  @db.Decimal(5, 2)  /// Arm for empty weight CG
  crew_arm_m            Decimal?  @db.Decimal(5, 2)  /// Arm for crew (pilot) CG
  passenger_arm_m       Decimal?  @db.Decimal(5, 2)  /// Arm for passenger CG
  baggage_arm_m         Decimal?  @db.Decimal(5, 2)  /// Arm for baggage CG
  freight_arm_m         Decimal?  @db.Decimal(5, 2)  /// Arm for freight CG
  fuel_arm_m            Decimal?  @db.Decimal(5, 2)  /// Arm for fuel CG

  created_at            DateTime  @default(now()) @db.Timestamptz()
  updated_at            DateTime  @default(now()) @db.Timestamptz()

  flights               flights[]
  airframe_hours        airframe_hours[]
  aircraft_assignments  aircraft_assignments[]
  loadsheets            loadsheets[]

  @@index([registration])
  @@map("aircraft")
}

/// Organizations (corporate / group bookings)
model organizations {
  id                       Int       @id @default(autoincrement())
  name                     String    @db.VarChar(255)
  code                     String?   @unique @db.VarChar(50)
  contact_email            String?   @db.VarChar(255)
  contact_phone            String?   @db.VarChar(50)
  billing_address          String?   @db.Text
  credit_limit_gbp         Decimal?  @db.Decimal(10, 2)
  is_active                Boolean   @default(true)
  payment_terms            String?   @default("net_30") @db.VarChar(30)
  default_payment_method_id String?  @db.Uuid
  tax_id                   String?   @db.VarChar(50)
  invoice_email            String?   @db.VarChar(255)
  credit_remaining_gbp     Decimal   @default(0) @db.Decimal(10, 2)
  created_at               DateTime  @default(now()) @db.Timestamptz()
  updated_at               DateTime  @default(now()) @db.Timestamptz()

  bookings  bookings[]
  invoices  invoices[]

  @@index([code])
  @@map("organizations")
}

/// Pilot records
model pilots {
  id              Int       @id @default(autoincrement())
  user_id         Int?
  name            String?   @db.VarChar(255)
  email           String?   @db.VarChar(255)
  license_number  String?   @db.VarChar(100)
  license_type    String?   @db.VarChar(50)
  medical_expiry  DateTime? @db.Date
  rating          String?   @db.VarChar(100)
  is_active       Boolean   @default(true)
  weight_kg       Decimal?  @default(80.0) @db.Decimal(5,1)
  created_at      DateTime  @default(now()) @db.Timestamptz()
  updated_at      DateTime  @default(now()) @db.Timestamptz()

  user                users?              @relation(fields: [user_id], references: [id], onDelete: SetNull)
  flights             flights[]
  flight_manifests    flight_manifests[]
  pilot_assignments   pilot_assignments[]
  loadsheets          loadsheets[]

  @@index([user_id])
  @@map("pilots")
}

/// Fare pricing between aerodromes
model fare_routes {
  id               Int       @id @default(autoincrement())
  origin_code      String    @db.VarChar(10)
  destination_code String    @db.VarChar(10)
  base_fare        Decimal   @db.Decimal(10, 2)
  base_fare_gbp    Decimal?  @db.Decimal(10, 2)
  currency         String    @default("GBP") @db.VarChar(10)
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now()) @db.Timestamptz()
  updated_at       DateTime  @default(now()) @db.Timestamptz()

  origin      aerodromes @relation("fare_route_origin", fields: [origin_code], references: [code])
  destination aerodromes @relation("fare_route_destination", fields: [destination_code], references: [code])

  @@index([is_active])
  @@map("fare_routes")
}

/// Scheduled flights
model flights {
  id                          Int       @id @default(autoincrement())
  flight_number               String    @unique @db.VarChar(20)
  origin_code                 String?   @db.VarChar(10)
  destination_code            String?   @db.VarChar(10)
  origin_aerodrome_id         Int?
  destination_aerodrome_id    Int?
  aircraft_id                 Int?
  pilot_id                    Int?
  departure_time              DateTime  @db.Timestamptz()
  arrival_time                DateTime  @db.Timestamptz()
  status                      String    @default("scheduled") @db.VarChar(50)
  available_seats             Int?
  base_fare                   Decimal?  @db.Decimal(10, 2)
  intermediate_stops          Json?     @db.JsonB
  total_passenger_weight_kg   Decimal?  @db.Decimal(8, 1)
  total_baggage_weight_kg     Decimal?  @db.Decimal(8, 1)
  total_freight_weight_kg     Decimal?  @db.Decimal(8, 1)
  total_fuel_weight_kg        Decimal?  @db.Decimal(8, 1)
  fuel_weight                 Decimal?  @default(0) @db.Decimal(10, 2)
  freight_weight              Decimal?  @default(0) @db.Decimal(10, 2)
  passenger_weight            Decimal?  @default(0) @db.Decimal(10, 2)
  crew_weight                 Decimal?  @default(0) @db.Decimal(10, 2)
  baggage_weight              Decimal?  @default(0) @db.Decimal(10, 2)
  pilot_approved_at           DateTime? @db.Timestamptz()
  schedule_id                 Int?
  fuel_required_l             Decimal?  @default(0) @db.Decimal(10, 2)
  fuel_on_board_l             Decimal?  @default(0) @db.Decimal(10, 2)
  pax_weight_kg               Decimal?  @default(0) @db.Decimal(10, 2)
  cargo_weight_kg             Decimal?  @default(0) @db.Decimal(10, 2)
  zero_fuel_weight_kg         Decimal?  @default(0) @db.Decimal(10, 2)
  sort_order                  Int?      @default(0)
  duration_minutes            Int?
  check_in_time               DateTime? @db.Time
  created_by                  Int?
  created_at                  DateTime  @default(now()) @db.Timestamptz()
  updated_at                  DateTime  @default(now()) @db.Timestamptz()

  origin_aerodrome      aerodromes?       @relation("flight_origin", fields: [origin_aerodrome_id], references: [id])
  destination_aerodrome aerodromes?       @relation("flight_destination", fields: [destination_aerodrome_id], references: [id])
  aircraft              aircraft?         @relation(fields: [aircraft_id], references: [id])
  pilot                 pilots?           @relation(fields: [pilot_id], references: [id])
  schedule              schedules?        @relation(fields: [schedule_id], references: [id])
  booking_legs          booking_legs[]
  checkin_reminders     checkin_reminders[]
  flight_manifests      flight_manifests[]
  notifications         notifications[]
  seat_assignments      seat_assignments[]
  flight_legs           flight_legs[]
  pilot_assignments     pilot_assignments[]
  aircraft_assignments  aircraft_assignments[]
  loadsheets            loadsheets[]
  published_flights     published_schedule_flights[]

  @@index([flight_number])
  @@index([status])
  @@index([origin_code])
  @@index([destination_code])
  @@index([schedule_id])
  @@index([aircraft_id, departure_time])
  @@map("flights")
}

/// Booking records
model bookings {
  id                      Int       @id @default(autoincrement())
  booking_reference       String    @unique @db.VarChar(20)
  user_id                 Int
  status                  String    @default("pending") @db.VarChar(50)
  organization_id         Int?
  is_organization_billing Boolean   @default(false)
  total_amount            Decimal   @default(0) @db.Decimal(10, 2)
  total_amount_gbp        Decimal?  @db.Decimal(10, 2)
  payment_status          String    @default("pending") @db.VarChar(50)
  payment_method          String?   @db.VarChar(50)
  payment_date            DateTime? @db.Timestamptz()
  payment_due_date        DateTime? @db.Date
  payment_terms           String?   @db.VarChar(30)
  stripe_session_id       String?   @db.VarChar(255)
  invoice_id              String?   @db.Uuid
  notes                   String?   @db.Text
  booking_source          String    @default("customer_direct") @db.VarChar(50)
  created_by              Int?
  cancelled_at            DateTime? @db.Timestamptz()
  cancelled_by            Int?
  cancellation_reason     String?   @db.Text
  created_at              DateTime  @default(now()) @db.Timestamptz()
  updated_at              DateTime  @default(now()) @db.Timestamptz()

  user              users?          @relation("booking_user", fields: [user_id], references: [id])
  organization      organizations?  @relation(fields: [organization_id], references: [id])
  created_by_user   users?          @relation("booking_created_by", fields: [created_by], references: [id])
  cancelled_by_user users?          @relation("booking_cancelled_by", fields: [cancelled_by], references: [id])
  invoice           invoices?       @relation("booking_invoice_ref", fields: [invoice_id], references: [id], onDelete: SetNull)

  booking_legs              booking_legs[]
  booking_passengers        booking_passengers[]
  checkin_reminders         checkin_reminders[]
  notifications             notifications[]
  payments                  payments[]
  payment_reminders         payment_reminders[]
  accounting_journal_entries  accounting_journal_entries[]
  invoices_by_booking       invoices[]                    @relation("invoice_booking")

  @@index([booking_reference])
  @@index([status])
  @@index([user_id])
  @@index([booking_source])
  @@index([created_by])
  @@index([payment_due_date])
  @@index([stripe_session_id])
  @@map("bookings")
}

/// Individual legs of a booking
model booking_legs {
  id                  Int       @id @default(autoincrement())
  booking_id          Int
  flight_id           Int?
  origin_code         String    @db.VarChar(10)
  destination_code    String    @db.VarChar(10)
  leg_date            DateTime  @db.Date
  departure_date      DateTime? @db.Date
  preferred_time      DateTime? @db.Time
  preferred_time_start DateTime? @db.Time
  preferred_time_end  DateTime? @db.Time
  leg_sequence        Int       @default(0)
  status              String    @default("pending") @db.VarChar(50)
  freight_description String?   @db.Text
  freight_weight      Decimal?  @default(0) @db.Decimal(10, 2)
  freight_weight_kg   Decimal?  @db.Decimal(8, 1)
  created_at          DateTime  @default(now()) @db.Timestamptz()
  updated_at          DateTime  @default(now()) @db.Timestamptz()

  booking       bookings    @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  flight        flights?    @relation(fields: [flight_id], references: [id])
  origin        aerodromes  @relation("bl_origin", fields: [origin_code], references: [code])
  destination   aerodromes  @relation("bl_destination", fields: [destination_code], references: [code])

  booking_leg_passengers booking_leg_passengers[]
  loadsheet_passengers   loadsheet_passengers[]

  @@index([booking_id])
  @@index([flight_id])
  @@map("booking_legs")
}

/// Passengers on a booking (renamed from passengers in migration 016)
model booking_passengers {
  id                      Int       @id @default(autoincrement())
  booking_id              Int
  user_id                 Int?
  first_name              String    @db.VarChar(100)
  last_name               String    @db.VarChar(100)
  email                   String?   @db.VarChar(255)
  phone                   String?   @db.VarChar(50)
  date_of_birth           DateTime? @db.Date
  nationality             String?   @db.VarChar(100)
  id_document_type        String?   @db.VarChar(50)
  id_document_number      String?   @db.VarChar(100)
  clothed_body_weight_kg  Decimal   @default(70) @db.Decimal(5, 1)
  residency_status        String?   @db.VarChar(50)
  salutation              String?   @db.VarChar(20)
  special_requirements    String?   @db.Text
  gender                  String?   @db.VarChar(50)
  passport_number         String?   @db.VarChar(100)
  discount_type           String?   @default("none") @db.VarChar(20)
  discount_percent        Decimal?  @default(0) @db.Decimal(5,1)
  created_at              DateTime  @default(now()) @db.Timestamptz()
  updated_at              DateTime  @default(now()) @db.Timestamptz()

  booking bookings @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  user    users?   @relation(fields: [user_id], references: [id])

  booking_leg_passengers booking_leg_passengers[]
  seat_assignments       seat_assignments[]
  checkin_reminders      checkin_reminders[]
  loadsheet_passengers   loadsheet_passengers[]

  @@index([booking_id])
  @@index([user_id])
  @@map("booking_passengers")
}

/// Seat assignments per flight
model seat_assignments {
  id            Int       @id @default(autoincrement())
  flight_id     Int
  passenger_id  Int
  seat_number   String    @db.VarChar(10)
  assigned_by   String    @default("system") @db.VarChar(50)
  assigned_at   DateTime  @default(now()) @db.Timestamptz()
  row_number    Int?
  column_letter String?   @db.VarChar(5)
  is_available  Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.Timestamptz()
  updated_at    DateTime  @default(now()) @db.Timestamptz()

  flight    flights            @relation(fields: [flight_id], references: [id], onDelete: Cascade)
  passenger booking_passengers @relation(fields: [passenger_id], references: [id])

  @@index([flight_id])
  @@index([passenger_id])
  @@map("seat_assignments")
}

/// Check-in reminder tracking
model checkin_reminders {
  id            Int       @id @default(autoincrement())
  flight_id     Int?
  booking_id    Int
  passenger_id  Int?
  scheduled_at  DateTime  @db.Timestamptz()
  sent_at       DateTime? @db.Timestamptz()
  status        String    @default("pending") @db.VarChar(50)
  reminder_type String?   @db.VarChar(50)
  scheduled_for DateTime? @db.Timestamptz()
  sent_via      String?   @db.VarChar(50)
  created_at    DateTime  @default(now()) @db.Timestamptz()
  updated_at    DateTime  @default(now()) @db.Timestamptz()

  flight  flights?  @relation(fields: [flight_id], references: [id], onDelete: Cascade)
  booking bookings  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  passenger booking_passengers? @relation(fields: [passenger_id], references: [id])

  @@index([flight_id])
  @@map("checkin_reminders")
}

/// Notification log
model notifications {
  id                Int       @id @default(autoincrement())
  booking_id        Int?
  flight_id         Int?
  user_id           Int?
  type              String    @db.VarChar(100)
  notification_type String?   @db.VarChar(100)
  recipient_email   String?   @db.VarChar(255)
  recipient_phone   String?   @db.VarChar(50)
  recipient_type    String?   @db.VarChar(50)
  subject           String?   @db.VarChar(255)
  message           String?   @db.Text
  status            String    @default("pending") @db.VarChar(50)
  sent_at           DateTime? @db.Timestamptz()
  created_at        DateTime  @default(now()) @db.Timestamptz()
  updated_at        DateTime  @default(now()) @db.Timestamptz()

  booking bookings? @relation(fields: [booking_id], references: [id])
  flight  flights?  @relation(fields: [flight_id], references: [id])
  user    users?    @relation(fields: [user_id], references: [id])

  @@index([booking_id])
  @@index([flight_id])
  @@index([status])
