  baggage_weight_kg         Decimal   @default(0) @db.Decimal(10, 2)
  freight_weight_kg         Decimal   @default(0) @db.Decimal(10, 2)
  fuel_weight_kg            Decimal   @default(0) @db.Decimal(10, 2)
  crew_weight_kg            Decimal   @default(0) @db.Decimal(10, 2)
  empty_weight_kg           Decimal   @default(0) @db.Decimal(10, 2)
  total_weight_kg           Decimal   @default(0) @db.Decimal(10, 2)
  required_fuel_kg          Decimal?  @db.Decimal(10, 2)
  minimum_fuel_kg           Decimal?  @db.Decimal(10, 2)
  fuel_state                String?   @db.VarChar(20)
  fuel_rule_applied         String?   @db.Text
  total_moment_kgm          Decimal?  @db.Decimal(10, 2)
  cg_position_pct           Decimal?  @db.Decimal(10, 2)
  effective_mtow_kg         Decimal?  @db.Decimal(10, 2)
  effective_mlw_kg          Decimal?  @db.Decimal(10, 2)
  mtow_used_pct             Decimal?  @db.Decimal(10, 2)
  mlw_used_pct              Decimal?  @db.Decimal(10, 2)
  binding_constraint        String?   @db.VarChar(20)
  binding_constraint_detail String?   @db.Text
  computed_by               String    @default("system") @db.VarChar(50)
  computed_at               DateTime? @default(now()) @db.Timestamptz()
  notes                     String?   @db.Text
  created_at                DateTime? @default(now()) @db.Timestamptz()
  updated_at                DateTime? @default(now()) @db.Timestamptz()

  flight_leg flight_legs @relation(fields: [flight_leg_id], references: [id], onDelete: Cascade)
  schedule   schedules?  @relation(fields: [schedule_id], references: [id], onDelete: Cascade)

  @@index([flight_leg_id])
  @@index([schedule_id])
  @@map("weight_balance_snapshots")
}

// ============================================================================
// RBAC TABLES (Migration 015)
// ============================================================================

/// Permission-based access control — roles
model roles {
  id              Int       @id @default(autoincrement())
  slug            String    @unique @db.VarChar(50)
  name            String    @db.VarChar(50)
  description     String?   @db.Text
  hierarchy_level Int       @default(0)
  is_system       Boolean   @default(false)
  created_at      DateTime  @default(now()) @db.Timestamptz()
  updated_at      DateTime  @default(now()) @db.Timestamptz()

  user_roles          user_roles[]
  role_permissions    role_permissions[]

  @@index([hierarchy_level])
  @@map("roles")
}

/// Permission-based access control — permissions
model permissions {
  id          Int      @id @default(autoincrement())
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  description String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamptz()

  role_permissions role_permissions[]

  @@unique([resource, action])
  @@map("permissions")
}

/// Permission-based access control — role-permission junction
model role_permissions {
  id            Int      @id @default(autoincrement())
  role_id       Int
  permission_id Int
  created_at    DateTime @default(now()) @db.Timestamptz()

  role        roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission  permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id])
  @@index([role_id])
  @@index([permission_id])
  @@map("role_permissions")
}

/// Permission-based access control — user-role junction
model user_roles {
  id          Int      @id @default(autoincrement())
  user_id     Int
  role_id     Int
  assigned_by Int?
  created_at  DateTime @default(now()) @db.Timestamptz()

  user        users  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role        roles  @relation(fields: [role_id], references: [id], onDelete: Cascade)
  assignedBy  users? @relation("user_role_assigned_by", fields: [assigned_by], references: [id], onDelete: SetNull)

  @@unique([user_id, role_id])
  @@index([user_id])
  @@index([role_id])
  @@map("user_roles")
}

/// Permission-based access control — audit log
model audit_log {
  id          Int      @id @default(autoincrement())
  actor_id    Int
  action      String   @db.VarChar(100)
  entity_type String?  @db.VarChar(50)
  entity_id   Int?
  old_values  Json?    @db.JsonB
  new_values  Json?    @db.JsonB
  ip_address  String?  @db.VarChar(45)
  user_agent  String?  @db.VarChar(255)
  assigned_by Int?
  created_at  DateTime @default(now()) @db.Timestamptz()

  actor        users @relation("audit_actor", fields: [actor_id], references: [id], onDelete: Restrict)
  assigned_by_user users? @relation("audit_assigned_by", fields: [assigned_by], references: [id])

  @@index([actor_id])
  @@index([action])
  @@index([entity_type, entity_id])
  @@index([created_at])
  @@map("audit_log")
}

