/// Rules that designate days on which flight bookings cannot be made
model no_fly_rules {
  id              Int           @id @default(autoincrement())
  label           String        @db.VarChar(255)
  description     String?       @db.Text
  rule_type       NoFlyRuleType
  is_active       Boolean       @default(true)
  day_of_week     Int[]         @default([])
  season_start    DateTime?     @db.Date
  season_end      DateTime?     @db.Date
  specific_date   DateTime?     @db.Date
  priority        Int           @default(0)
  override_reason String?       @db.Text
  created_by      Int
  created_at      DateTime      @default(now()) @db.Timestamptz()
  updated_at      DateTime      @default(now()) @db.Timestamptz()

  created_user users @relation(fields: [created_by], references: [id])

  @@index([is_active])
  @@index([specific_date])
  @@index([day_of_week])
  @@map("no_fly_rules")
}

