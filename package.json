{
  "name": "figas",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "npm run db:types && remix vite:build",
    "dev": "remix vite:dev",
    "postinstall": "prisma generate && npm run db:types",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "npm run db:types && tsc",
    "migrate": "node --env-file-if-exists=.env --import tsx app/utils/migrate.ts",
    "db:push": "prisma db push",
    "db:types": "node --import tsx scripts/generate-kysely-types.ts",
    "db:reset": "node --env-file-if-exists=.env --import tsx scripts/reset-db.ts",
    "db:reseed": "npm run db:reset && npm run seed:comprehensive && npm run seed:pbac && npm run seed:pbac:assign",
    "seed": "node --env-file-if-exists=.env --import tsx app/utils/seed.ts",
    "seed:users": "node --env-file-if-exists=.env --import tsx scripts/seed-users.ts",
    "seed:pbac": "node --env-file-if-exists=.env --import tsx prisma/seed-pbac.ts",
    "seed:pbac:assign": "node --env-file-if-exists=.env --import tsx scripts/assign-user-roles.ts",
    "seed:full": "node --env-file-if-exists=.env --import tsx scripts/seed-full.ts",
    "seed:comprehensive": "node --env-file-if-exists=.env --import tsx scripts/seed-comprehensive.ts",
    "seed:parity": "node --env-file-if-exists=.env --import tsx scripts/seed-parity-test.ts",
    "seed:all": "node --env-file-if-exists=.env --import tsx scripts/seed-users.ts && node --env-file-if-exists=.env --import tsx prisma/seed-pbac.ts && node --env-file-if-exists=.env --import tsx scripts/assign-user-roles.ts",
    "bootstrap": "npm run migrate && npm run db:push && npm run seed:comprehensive && npm run seed:pbac && npm run seed:pbac:assign",
    "setup": "npm run bootstrap",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test",
    "test:related": "node scripts/ci/detect-changed-suites.js --run",
    "test:smoke": "vitest run tests/smoke",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --check"
    ],
    "*.{ts,tsx,js,cjs,mjs,json,css,md}": [
      "prettier --check"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "@remix-run/node": "^2.15.3",
    "@remix-run/react": "^2.15.3",
    "@remix-run/serve": "^2.16.4",
    "bcryptjs": "^3.0.3",
    "driver.js": "^1.6.0",
    "isbot": "^4.1.0",
    "kysely": "^0.29.3",
    "lucide-react": "^1.17.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shiki": "^3.0.0",
    "stripe": "^22.1.1",
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@remix-run/dev": "^2.15.3",
    "@tailwindcss/postcss": "^4.0.6",
    "@tailwindcss/typography": "^0.5.16",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "dotenv": "^17.4.2",
    "eslint": "^8.38.0",
    "eslint-import-resolver-typescript": "^3.8.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "postcss": "^8.4.38",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.0.6",
    "tsx": "^4.22.0",
    "typescript": "^5.1.6",
    "vite": "^5.4.16",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
