{
  "name": "remix-admin-template",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "tsc",
    "migrate": "node --env-file .env --import tsx app/utils/migrate.ts",
    "seed": "node --env-file .env --import tsx app/utils/seed.ts",
    "seed:users": "node --env-file .env --import tsx scripts/seed-users.ts",
    "seed:pbac": "node --env-file .env --import tsx prisma/seed-pbac.ts",
    "seed:pbac:assign": "node --env-file .env --import tsx scripts/assign-user-roles.ts",
    "seed:full": "node --env-file .env --import tsx scripts/seed-full.ts",
    "seed:all": "node --env-file .env --import tsx scripts/seed-users.ts && node --env-file .env --import tsx prisma/seed-pbac.ts && node --env-file .env --import tsx scripts/assign-user-roles.ts",
    "setup": "npm run migrate && npm run seed:full && npm run seed:pbac && npm run seed:pbac:assign",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@netlify/remix-adapter": "^2.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "@remix-run/node": "^2.15.3",
    "@remix-run/react": "^2.15.3",
    "@remix-run/serve": "^2.16.4",
    "bcryptjs": "^3.0.3",
    "isbot": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shiki": "^3.0.0",
    "stripe": "^22.1.1",
    "timepicker-ui": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@remix-run/dev": "^2.15.3",
    "@tailwindcss/postcss": "^4.0.6",
    "@tailwindcss/typography": "^0.5.16",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "eslint": "^8.38.0",
    "eslint-import-resolver-typescript": "^3.8.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^4.0.6",
    "tsx": "^4.22.0",
    "typescript": "^5.1.6",
    "vite": "^5.4.16",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
