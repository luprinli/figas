# Install devDependencies during installs even when NODE_ENV=production.
#
# Render sets NODE_ENV=production on the service, which makes `npm ci` omit
# devDependencies by default. The build needs several of them (@remix-run/dev,
# vite, tailwindcss) and the pre-deploy step needs prisma + tsx. Forcing
# include=dev here guarantees they are installed regardless of how the build
# command is configured or synced.
include=dev
