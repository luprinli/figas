          orderBy: { id: "asc" },
          take: 1,
        },
      },
      orderBy: { created_at: "desc" },
    }),
  ]);

  return {
    bookings: rows.map((row) => ({
      booking: row as unknown as BookingRow,
      firstLeg: row.booking_legs[0] ? { /* ... */ } : null,
      passenger: row.booking_passengers[0] ? { /* ... */ } : null,
