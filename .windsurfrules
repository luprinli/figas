## Examples

### Route with Permission Guard

```typescript
// app/routes/operations.schedule._index.tsx (simplified)
import { requirePermission, hasPermission } from "../utils/permissions.server";
import { Permission } from "../utils/constants";

export async function loader({ request }: LoaderFunctionArgs) {
  // Gate the entire route
  const user = await requirePermission(request, Permission.SCHEDULE_CREATE);

  // Granular checks for specific actions
  const canApprove = await hasPermission(Number(user.id), Permission.SCHEDULE_APPROVE);
  const canPublish = await hasPermission(Number(user.id), Permission.SCHEDULE_PUBLISH);

  return json({
    canApprove,
    canPublish,
    // ... data
  });
}

export default function SchedulePage() {
  const { canApprove, canPublish } = useLoaderData<typeof loader>();

  return (
    <div>
      {canApprove && <button>Approve</button>}
      {canPublish && <button>Publish</button>}
    </div>
  );
}
```

### Role Assignment with SoD Check

```typescript
import { assignRole, revokeRole } from "../utils/permissions.server";

// In an action function
export async function action({ request }: ActionFunctionArgs) {
  const actor = await requirePermission(request, Permission.USER_ASSIGN_ROLE);
  const formData = await request.formData();
  const targetUserId = Number(formData.get("userId"));
  const roleId = Number(formData.get("roleId"));

  try {
    // assignRole() internally calls validateSoDForRole() + createAuditLogEntry()
    await assignRole(Number(actor.id), targetUserId, roleId);
    return json({ success: true });
  } catch (error) {
    return json({ error: (error as Error).message }, { status: 400 });
  }
}
```

### Audit Log Query

```typescript
import { queryAuditLog } from "../utils/permissions.server";

// Fetch recent role assignment audit entries
const result = await queryAuditLog({
  action: "role.assigned",
  dateFrom: new Date("2025-01-01"),
  page: 1,
  perPage: 20,
