## Data Flow

### Server → Client

```
Loader (server) → json() → useLoaderData() (client) → Component props
```

```typescript
// 1. Define LoaderData interface at top of route file
interface LoaderData {
  schedule: Awaited<ReturnType<typeof scheduleRepository.findByDate>>;
  flights: FlightSummaryRow[];
  canApprove: boolean;
}

// 2. Return typed JSON from loader
return json<LoaderData>({ schedule, flights, canApprove });

// 3. Destructure in component
export default function Page() {
  const { schedule, flights, canApprove } = useLoaderData<LoaderData>();
  // ...
}
```

### Form Submissions

Two patterns depending on the interaction type:

**Pattern 1: Navigation-based (`<Form>`)**
Use for primary actions that should navigate/refresh the page (e.g., approve, publish):

```typescript
<Form method="post" className="inline">
  <input type="hidden" name="intent" value="approve" />
  <input type="hidden" name="scheduleId" value={schedule.id} />
  <button type="submit">Approve</button>
</Form>
```

**Pattern 2: Fetcher-based (`useFetcher()`)**
Use for inline actions that should NOT navigate (e.g., drag-and-drop, inline edits):

```typescript
const fetcher = useFetcher();

function handleDropOnFlight(bookingLegId: number, flightId: number) {
  const formData = new FormData();
  formData.set("intent", "assign-booking");
  formData.set("bookingLegId", String(bookingLegId));
  formData.set("flightId", String(flightId));
  fetcher.submit(formData, { method: "post" });
}
```

### Optimistic Updates

Used in the schedule builder for drag-and-drop operations. Pattern:

```typescript
// 1. Track pending operations with useRef
const pendingOpsRef = useRef<PendingOp[]>([]);

// 2. Save snapshot before mutation
pendingOpsRef.current.push({
  type: "assign",
  snapshot: { flights: [...flights], assignedIds: new Set(assignedMockIds) },
  timestamp: Date.now(),
});

// 3. Apply optimistic update immediately
setAssignedMockIds((prev) => new Set(prev).add(bookingLegId));

// 4. Submit to server
fetcher.submit(formData, { method: "post" });

// 5. Rollback on error (in useEffect watching fetcher.data)
function handleRollback(error: string) {
  const op = pendingOpsRef.current.pop();
  if (!op) return;
  setFlights(op.snapshot.flights);
  setAssignedMockIds(new Set(op.snapshot.assignedIds));
  showToast(`Action reverted: ${error}`, "error");
}
```

