# =============================================================================
# FIGAS Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# NEVER commit the real .env file to version control.
# =============================================================================

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma and raw-pg scripts.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/figas

# ── Session ────────────────────────────────────────────────────────────────────
# Secret used to sign session cookies. Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-session-secret-here

# ── CSRF Protection ────────────────────────────────────────────────────────────
# Secret used to sign CSRF tokens. Should be different from SESSION_SECRET.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=your-csrf-secret-here

# ── Stripe (Payments) ──────────────────────────────────────────────────────────
# Get test keys from https://dashboard.stripe.com/test/apikeys
# Use sk_test_... for development, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Webhook signing secret from Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Environment ────────────────────────────────────────────────────────────────
# Set to "production" in production, "development" locally.
# Controls cookie security, Prisma log level, and other runtime behaviour.
NODE_ENV=development

# ── Application ─────────────────────────────────────────────────────────────────
# Base URL used for generating links in emails and reset-password flows.
APP_URL=http://localhost:5173

# ── Contact Information ─────────────────────────────────────────────────────────
# Displayed in print templates (loadsheets, tickets, schedules).
CONTACT_EMAIL=ops@figas.gov.fk
CONTACT_PHONE=+500 27219
SYSTEM_EMAIL=system@figas.gov.fk

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Used by app/utils/email.server.ts for all transactional emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user
SMTP_PASS=pass
SMTP_FROM=noreply@figas.gov.fk

# ── Scheduling ─────────────────────────────────────────────────────────────────
# Set to "true" to block schedule approval when W&B violations exist.
# Default (unset or "false"): violations logged as warnings but approval proceeds.
WB_VIOLATIONS_BLOCK_APPROVAL=false

# ── Stripe API Version ──────────────────────────────────────────────────────────
# Pin to a specific Stripe API version to prevent breaking changes.
STRIPE_API_VERSION=2026-04-22.dahlia


